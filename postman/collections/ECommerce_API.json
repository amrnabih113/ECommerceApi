            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cart/summary",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "summary"]
            },
            "description": "Get cart summary with totals: subtotal, tax (14%), discount, and total amount"
          },
          "response": []
        },
        {
          "name": "Add to Cart (Products WITH Variants)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 2,\n  \"productId\": 1,\n  \"productVariantId\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cart/items",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "items"]
            },
            "description": "Add item to cart. For products WITH variants (HasVariants=true), productVariantId is REQUIRED. Stock validation occurs at variant level. Automatically creates cart on first add"
          },
          "response": []
        },
        {
          "name": "Add to Cart (Products WITHOUT Variants)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 1,\n  \"productId\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cart/items",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "items"]
            },
            "description": "Add item to cart. For products WITHOUT variants (HasVariants=false), productVariantId must be NULL/omitted. Stock validation occurs at product level"
          },
          "response": []
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cart/items/{{cartItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "items", "{{cartItemId}}"]
            },
            "description": "Update quantity for cart item. Stock validation applies (must have sufficient stock for new quantity)"
          },
          "response": []
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cart/items/{{cartItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "items", "{{cartItemId}}"]
            },
            "description": "Remove a specific item from cart"
          },
          "response": []
        },
        {
          "name": "Clear Cart",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
